
# ============================================================================
# DOCKER & DEPLOYMENT CONFIGURATION
# ============================================================================

# Docker Registry & Image Configuration
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username

# Crimson Oracle (Java Backend Service)
JAVA_IMAGE_NAME=crimson-oracle
JAVA_IMAGE_TAG=latest

# Emerald Engine (Python AI/ML Service)
PYTHON_IMAGE_NAME=emerald-engine
PYTHON_IMAGE_TAG=latest
PYTHON_REPO_URL=https://github.com/PacerLabs/Eev-Build-AI.git
PYTHON_REPO_BRANCH=main

# Sapphire Nexus (Next.js Frontend Service)
NEXTJS_IMAGE_NAME=sapphire-nexus
NEXTJS_IMAGE_TAG=latest

# ============================================================================
# DATABASE CONFIGURATION (Titan Vault - PostgreSQL)
# ============================================================================

# PostgreSQL Connection (Titan Vault - Internal)
DATABASE_URL=jdbc:postgresql://titan-vault:5432/eev_db
DATABASE_USERNAME=postgres

# Database Credentials - PRESET (modify if needed)
# NOTE: Highly complex password mixing hex, binary, and special characters
DATABASE_PASSWORD=7f9e4a2b10110101@K9mL2nP$0xA3F5C7!11001100zQ8vR4sT%0x5e9d2c&1010111001@xW6yZ3pU$0xB7E1A9!10011010mN5oL1qJ%0xF3C6B8&11110000@jK2hG7dF$0x4E2D9A!10101010

# ============================================================================
# SPRING BOOT / JAVA CONFIGURATION
# ============================================================================

# Datasource Configuration
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# Flyway Migration Configuration
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true

# Spring Core Configuration
SPRING_MAIN_ALLOW_BEAN_DEFINITION_OVERRIDING=true
SPRINGDOC_DEFAULT_PRODUCES_MEDIA_TYPE=application/json

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# JWT Configuration - PRESET (modify if needed)
JWT_SECRET_TOKEN=n8T2YFv1Q8z5X+7vYcKfJ9s8K1kU0OQZ2w7hXbL3pQk=
JWT_EXPIRATION_TIME=7

# API Keys - REQUIRED (update with your values)
API_KEY=1a4f521145655d41bacf1d5a179d5b4a8c2de6a3f33d37452118d11cc84d78f8e9f52d96582a34b27c5653ab93a9b08ef389745290741715c77c8e31a824bcce
ENDPOINT_AUTH_KEY=your_endpoint_auth_key

# ============================================================================
# BACKEND SERVICE CONFIGURATION (Crimson Oracle)
# ============================================================================

# Crimson Oracle (Java Backend)
SERVER_PORT=8086
SERVER_URL=https://eev-management-staging.optimusai.ai/
LICENSE_SERVICE_BASE_URL=http://crimson-oracle:8086

# ============================================================================
# FRONTEND SERVICE CONFIGURATION (Sapphire Nexus)
# ============================================================================

# Sapphire Nexus (Next.js Frontend)
SERVICE_FQDN_APP=http://sapphire-nexus:3010
SERVICE_URL_APP=http://sapphire-nexus:3010
NEXT_PUBLIC_BASE_URI=http://localhost:8000/api/v1
NEXT_PUBLIC_SERVER_URI=http://localhost:8086/api/v1
NEXT_PUBLIC_OG_IMAGE=

# ============================================================================
# AI/ML SERVICE CONFIGURATION (Emerald Engine)
# ============================================================================

# Emerald Engine (Python AI/ML Service)
SERVICE_FQDN_API=http://emerald-engine:8000
SERVICE_URL_API=http://emerald-engine:8000
AI_URL=http://emerald-engine:8000

# AI Service Defaults
NIXPACKS_NODE_VERSION=18

# ============================================================================
# EXTERNAL AI/ML API KEYS - REQUIRED
# ============================================================================

# OpenAI Configuration (Required for AI features)
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_NAME=text-embedding-3-small

# Gemini API Configuration (Required for AI features)
GEMINI_API_KEY=your_gemini_api_key

# Pinecone Vector Database Configuration (Required for vector database)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Resend Email Service Configuration (Required for email features)
RESEND_API=your_resend_api_key

# ============================================================================
# CACHE CONFIGURATION (Nebula Cache - Redis)
# ============================================================================

# Nebula Cache (Redis)
MEMORY_DB=redis://nebula-cache:6379
